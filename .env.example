# Postgres bootstrap superuser (used only by the DB container init)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Database role that owns schema and is intended for manual DB access
AIDA26_OWNER_USER=aida26_owner

# Database role used by backend app connection
AIDA26_APP_USER=aida26_user
AIDA26_APP_PASSWORD=CHANGE_ME_APP_PASSWORD

# Dedicated DDL credentials for Schema Studio operations
SCHEMA_STUDIO_DB_USER=CHANGE_ME_DDL_USER
SCHEMA_STUDIO_DB_PASSWORD=CHANGE_ME_DDL_PASSWORD

# Host ports
APP_PORT=3000
DB_EXPOSE_PORT=5432

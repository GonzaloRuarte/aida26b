# Postgres bootstrap superuser (used only by the DB container init)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Database role that owns schema and is intended for manual DB access
AIDA26_OWNER_USER=aida26_owner

# Database role used by backend app connection
AIDA26_APP_USER=aida26_user
AIDA26_APP_PASSWORD=app_local_password

# Host ports
APP_PORT=3000
DB_EXPOSE_PORT=5432
